<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" xmlns:bioc="http://bpmn.io/schema/bpmn/biocolor/1.0" xmlns:color="http://www.omg.org/spec/BPMN/non-normative/color/1.0" xmlns:fluxnova="http://fluxnova.finos.org/schema/1.0/bpmn" id="Definitions_0juelhz" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Fluxnova Modeler" exporterVersion="1.0-SNAPSHOT">
  <bpmn:process id="LoanApplicationProcess" name="Loan Application" isExecutable="true" camunda:historyTimeToLive="1">
    <bpmn:startEvent id="StartEvent_LoanRequestReceived" name="Loan Request Received" camunda:formRef="loanRequestStartForm" camunda:formRefBinding="latest">
      <bpmn:extensionElements>
        <camunda:executionListener expression="${processCreateListener.notify(execution)}" event="start" />
      </bpmn:extensionElements>
      <bpmn:outgoing>Flow_0mlm3f4</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:userTask id="Task_ReviewLoan" name="Review Loan" camunda:formRef="loanRequestReviewForm" camunda:formRefBinding="latest">
      <bpmn:extensionElements>
        <camunda:taskListener expression="${taskCreateListener.notify(task)}" event="create" id="" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_0y6ca6i</bpmn:incoming>
      <bpmn:outgoing>SequenceFlow_0vmrnri</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="Gateway_IsLoanRequestApproved" name="Approved?" default="Flow_LoanRequestRejected">
      <bpmn:incoming>SequenceFlow_0vmrnri</bpmn:incoming>
      <bpmn:incoming>Flow_02g0u2w</bpmn:incoming>
      <bpmn:outgoing>Flow_LoanRequestApproved</bpmn:outgoing>
      <bpmn:outgoing>Flow_LoanRequestRejected</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sequenceFlow id="SequenceFlow_0vmrnri" sourceRef="Task_ReviewLoan" targetRef="Gateway_IsLoanRequestApproved" />
    <bpmn:sequenceFlow id="Flow_LoanRequestApproved" name="Yes" sourceRef="Gateway_IsLoanRequestApproved" targetRef="Task_CreateLoanAccount">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${loanReviewService.isApproved(execution)}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="SequenceFlow_1irh9ey" sourceRef="Task_CreateLoanAccount" targetRef="Task_SendNotification" />
    <bpmn:endEvent id="EndEvent_LoanRequestProcessed" name="Loan Request Processed">
      <bpmn:extensionElements />
      <bpmn:incoming>SequenceFlow_0jhkwyh</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="SequenceFlow_0jhkwyh" sourceRef="Task_SendNotification" targetRef="EndEvent_LoanRequestProcessed" />
    <bpmn:sequenceFlow id="Flow_LoanRequestRejected" name="No" sourceRef="Gateway_IsLoanRequestApproved" targetRef="Task_SendNotification" />
    <bpmn:serviceTask id="Task_CreateLoanAccount" name="Create Loan Account" camunda:type="external" camunda:topic="createLoanAccount">
      <bpmn:incoming>Flow_LoanRequestApproved</bpmn:incoming>
      <bpmn:outgoing>SequenceFlow_1irh9ey</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_SendNotification" name="Send Notification" camunda:expression="${sendNotificationDelegate.execute(execution)}">
      <bpmn:incoming>SequenceFlow_1irh9ey</bpmn:incoming>
      <bpmn:incoming>Flow_LoanRequestRejected</bpmn:incoming>
      <bpmn:outgoing>SequenceFlow_0jhkwyh</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="Flow_0mlm3f4" sourceRef="StartEvent_LoanRequestReceived" targetRef="Task_CalculateEligibleAmount" />
    <bpmn:sequenceFlow id="Flow_0y6ca6i" sourceRef="Task_CalculateEligibleAmount" targetRef="Task_ReviewLoan" />
    <bpmn:businessRuleTask id="Task_CalculateEligibleAmount" name="Calculate Eligible Amount" camunda:resultVariable="eligibleAmount" camunda:decisionRef="Decision_CalculateEligibleAmount" camunda:mapDecisionResult="singleEntry">
      <bpmn:extensionElements />
      <bpmn:incoming>Flow_0mlm3f4</bpmn:incoming>
      <bpmn:outgoing>Flow_0y6ca6i</bpmn:outgoing>
    </bpmn:businessRuleTask>
    <bpmn:boundaryEvent id="Event_1MinTimer" name="1 min timer" attachedToRef="Task_ReviewLoan">
      <bpmn:outgoing>Flow_02g0u2w</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerEventDefinition_1w8xs7i">
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">PT1M</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>
    <bpmn:sequenceFlow id="Flow_02g0u2w" sourceRef="Event_1MinTimer" targetRef="Gateway_IsLoanRequestApproved" />
    <bpmn:textAnnotation id="TextAnnotation_0vcq4pg">
      <bpmn:text>DMN Rule task which calculates eligible loan amount based on age, occupation. See calculate_eligible_amount.dmn</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_0h3zbpr" associationDirection="None" sourceRef="Task_CalculateEligibleAmount" targetRef="TextAnnotation_0vcq4pg" />
    <bpmn:textAnnotation id="TextAnnotation_0pjndqg">
      <bpmn:text>User task needs to be completed by human</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_1yi5mge" associationDirection="None" sourceRef="Task_ReviewLoan" targetRef="TextAnnotation_0pjndqg" />
    <bpmn:textAnnotation id="TextAnnotation_14yyu0h">
      <bpmn:text>Service task - gets completed by External task worker pattern - polled by CreateLoanAccountTaskHandler.java</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_1dity6k" associationDirection="None" sourceRef="Task_CreateLoanAccount" targetRef="TextAnnotation_14yyu0h" />
    <bpmn:textAnnotation id="TextAnnotation_0la0vi5">
      <bpmn:text>Service task
- gets completed by Delegate pattern
- calls SendNotificationDelegate.java</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_0pxrufd" associationDirection="None" sourceRef="Task_SendNotification" targetRef="TextAnnotation_0la0vi5" />
    <bpmn:textAnnotation id="TextAnnotation_087kedr">
      <bpmn:text>This sequence flow has condition. The process will take this path if it evaluates to true.
See Condition in Properties panel for this sequence flow. It calls LoanReviewService.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_04b4s6o" associationDirection="None" sourceRef="Flow_LoanRequestApproved" targetRef="TextAnnotation_087kedr" />
    <bpmn:textAnnotation id="TextAnnotation_0zmju9o">
      <bpmn:text>Executes TaskCreateListener when this user task gets created and before it becomes available to users.
See Task Listeners in Properties panel for this user task.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_0i5k74g" associationDirection="None" sourceRef="Task_ReviewLoan" targetRef="TextAnnotation_0zmju9o" />
    <bpmn:textAnnotation id="TextAnnotation_1da52b8">
      <bpmn:text>This sequence flow is default, and has no condition. The process will take the default path, if all other outgoing paths from exclusive gateways evaluate to false</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_0mu5j8c" associationDirection="None" sourceRef="Flow_LoanRequestRejected" targetRef="TextAnnotation_1da52b8" />
    <bpmn:textAnnotation id="TextAnnotation_1149r0h">
      <bpmn:text>Timer event interrupts the User task if not actioned within 1 min. The process will then take default sequence flow.
See Time in Properties panel for this Timer event.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_05ggkzs" associationDirection="None" sourceRef="Event_1MinTimer" targetRef="TextAnnotation_1149r0h" />
  </bpmn:process>
  <bpmn:message id="Message_017mzpg" name="catch_message_reject_exception" />
  <bpmn:message id="Message_1lakcer" name="catch_message_EDR_exception" />
